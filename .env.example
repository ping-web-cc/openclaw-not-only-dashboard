# OpenAI API Key (for TTS voice synthesis / 用於 TTS 語音合成)
# Required only if you use OpenAI TTS. Browser TTS works without it.
# 只在使用 OpenAI TTS 時需要，瀏覽器內建 TTS 不需要此設定。
OPENAI_API_KEY=sk-...

# Optional: custom port (default 18790 / 可選：自訂 port，預設 18790)
# PORT=18790

# Optional: OpenClaw gateway URL (default http://localhost:18789)
# 可選：OpenClaw gateway 位址（預設 http://localhost:18789）
# OPENCLAW_GATEWAY=http://localhost:18789
